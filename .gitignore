# --- Private / non-public material (present on disk, never published) --------
# Working folders that contain third-party copyrighted PDFs, the unpublished
# manuscript, the pitch, etc. They live in the private archive repo, not here.
/literature/
/book-draft/
/pitch/
/materials/
*.pdf
*.docx
*.doc
*.jpeg

# --- Case content (pulled at build time from the cases repo) -----------------
# Authors edit cases in crimes-against-causality/cases. CI clones it here; for
# local builds, run:  make cases   (clones/updates case-studies/)
/case-studies/

# --- Generated by scripts/build-book.R (never committed here) -----------------
/book/cases/
/book/solutions/
/book/references.qmd
/book/appendix-index.qmd
/book/intro/detectives.qmd
/book/intro/world.qmd
/book/_quarto.yml

# --- Quarto render output ----------------------------------------------------
book/_book/
book/.quarto/
/.quarto/

# --- Tooling -----------------------------------------------------------------
.claude/launch.json

# --- R -----------------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/

# --- macOS / Office ----------------------------------------------------------
.DS_Store
~$*
